# LynkMesh Autopilot Engineer configuration
# Keep real keys only in .env. Never commit .env to GitHub.

# Set false to use real Qwen Cloud API. Use `python -m agent.main --mock` for deterministic local demo.
MOCK_QWEN=false

# Use either QWEN_API_KEY or DASHSCOPE_API_KEY.
QWEN_API_KEY=
DASHSCOPE_API_KEY=

# Qwen Cloud / Alibaba Model Studio OpenAI-compatible endpoint.
# Example workspace endpoint:
# https://ws-xxxxx.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://ws-xxxxx.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT_SECONDS=60
